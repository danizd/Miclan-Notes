# Copia este fiche comme .env y ajusta los valores a tu entorno

# Ruta absoluta al directorio de notas
# Desarrollo: ruta local de tu máquina
# Producción: /mnt/notas (montaje NFS)
NOTES_DIR=/ruta/a/tus/notas

# Puerto del servidor (dentro y fuera del contenedor son el mismo)
PORT=3000

# URL base de la API accesible desde el navegador
# Desarrollo: http://localhost:3000
# Producción: http://100.121.99.57:3000
VITE_API_URL=http://localhost:3000
